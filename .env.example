# `id` and `hash` can be obtained by this guide: https://core.telegram.org/api/obtaining_api_id
API_ID=000000
API_HASH=string

# Single bot
BOT_TOKEN=

# Multiple bots: JSON object mapping session name → token
# Session files: data/{name}.session, data files: data/{name}.json
# BOTS={"nora": "token1", "rkn_chan": "token2"}

PERSONA_KEY=default_persona_filename
ALLOWED_USERS=telegram_user_id

# Connection to LLM API
LLM_URL=http://localhost:11434
LLM_MODEL=gemma3:4b
LLM_API_KEY=local # put here key, if use cloud API

# `separate` asks description of media using local model, then pass to API
LLM_VISION=separate 
LLM_VISION_URL=http://localhost:11434
LLM_VISION_MODEL=gemma3:4b